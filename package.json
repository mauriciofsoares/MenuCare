{
  "name": "menucare",
  "version": "1.0.0",
  "description": "",
  "main": "portal.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "npm run test:all",
    "test:api": "npm run test --workspace apps/api",
    "test:web": "npm run test --workspace apps/web --if-present",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "test:e2e:install": "playwright install chromium",
    "test:all": "npm run test:api && npm run test:web",
    "dev": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "build": "npm run build:all",
    "build:api": "npm run build --workspace apps/api",
    "build:web": "npm run build --workspace apps/web",
    "build:all": "npm run build:api && npm run build:web",
    "ci:validate": "npm run test:all && npm run build:all",
    "branch-protection:apply": "powershell -ExecutionPolicy Bypass -File ./scripts/github/apply-branch-protection.ps1",
    "governance:audit:dispatch": "powershell -ExecutionPolicy Bypass -File ./scripts/github/dispatch-governance-audit.ps1",
    "governance:audit:new": "powershell -ExecutionPolicy Bypass -File ./scripts/governance/new-monthly-audit.ps1 -SkipIfExists",
    "governance:audit:check": "powershell -ExecutionPolicy Bypass -File ./scripts/governance/check-monthly-audit.ps1",
    "governance:audit:check:strict": "powershell -ExecutionPolicy Bypass -File ./scripts/governance/check-monthly-audit.ps1 -Strict",
    "lint": "npm run lint --workspace apps/web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prisma:generate": "npm run prisma:generate --workspace apps/api",
    "prisma:migrate": "npm run prisma:migrate --workspace apps/api"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
